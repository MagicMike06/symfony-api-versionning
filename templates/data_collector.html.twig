{% extends '@WebProfiler/Profiler/layout.html.twig' %}

{% block toolbar %}
    {% set icon %}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M11 6h-6a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-6"/>
            <path d="M14 4h6v6"/>
            <path d="M11 13l7 -7"/>
        </svg>
        <span class="sf-toolbar-value">
            {{ collector.resolvedVersion ?? '—' }}
        </span>
        {% if collector.transformations|length > 0 %}
            <span class="sf-toolbar-info-piece-additional-detail">
                {{ collector.transformations|length }} transform.
            </span>
        {% endif %}
    {% endset %}

    {% set text %}
        <div class="sf-toolbar-info-piece">
            <b>Version client</b>
            <span>{{ collector.resolvedVersion ?? '<em>none</em>'|raw }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Header</b>
            <span>{{ collector.headerName }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Transformations</b>
            <span>{{ collector.transformations|length }}</span>
        </div>
        <div class="sf-toolbar-info-piece">
            <b>Total overhead</b>
            <span>{{ collector.totalDurationMs|number_format(2) }} ms</span>
        </div>
    {% endset %}

    {% set status = collector.wasVersioned ? 'normal' : '' %}
    {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: profiler_url, status: status }) }}
{% endblock %}

{% block menu %}
    <span class="label {{ not collector.wasVersioned ? 'disabled' }}">
        <span class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M11 6h-6a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-6"/>
                <path d="M14 4h6v6"/>
                <path d="M11 13l7 -7"/>
            </svg>
        </span>
        <strong>API Version</strong>
    </span>
{% endblock %}

{% block panel %}
    <h2>API Versioning</h2>

    {# Summary metrics #}
    <div class="metrics">
        <div class="metric">
            <span class="value">{{ collector.resolvedVersion ?? '—' }}</span>
            <span class="label">Version client</span>
        </div>
        <div class="metric">
            <span class="value">{{ collector.registeredVersions|length }}</span>
            <span class="label">Versions enregistrées</span>
        </div>
        <div class="metric">
            <span class="value">{{ collector.appliedVersionNames|length }}</span>
            <span class="label">Appliquées</span>
        </div>
        <div class="metric">
            <span class="value">{{ collector.totalDurationMs|number_format(2) }} ms</span>
            <span class="label">Total overhead</span>
        </div>
    </div>

    {# Passthrough notice #}
    {% if not collector.wasVersioned %}
        <div class="empty">
            <p>
                <strong>Passthrough</strong> — aucun header <code>{{ collector.headerName }}</code> reçu.
                Les transformations de versionnage n'ont pas été appliquées.
            </p>
        </div>
    {% else %}
        {# Route & header info #}
        <h3>Informations de la requête</h3>
        <table>
            <thead>
                <tr>
                    <th>Clé</th>
                    <th>Valeur</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Header utilisé</td>
                    <td><code>{{ collector.headerName }}</code></td>
                </tr>
                <tr>
                    <td>Valeur du header</td>
                    <td><code>{{ collector.resolvedVersion }}</code></td>
                </tr>
                <tr>
                    <td>Route Symfony</td>
                    <td><code>{{ collector.routeName ?: '—' }}</code></td>
                </tr>
                <tr>
                    <td>Versions en retard</td>
                    {% set gap = collector.appliedVersionNames|length %}
                    <td>
                        {% if gap == 0 %}
                            <span style="color: var(--color-success, #4f8a10);">À jour</span>
                        {% elseif gap <= 2 %}
                            <span style="color: var(--color-warning, #976400);">{{ gap }} version(s) de retard</span>
                        {% else %}
                            <span style="color: var(--color-error, #b0413e);">{{ gap }} versions de retard</span>
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>

        {# Applied transformations #}
        {% if collector.transformations|length > 0 %}
            <h3>Transformations appliquées</h3>
            <table>
                <thead>
                    <tr>
                        <th>Direction</th>
                        <th>Version</th>
                        <th>Description</th>
                        <th class="text-right">Durée</th>
                    </tr>
                </thead>
                <tbody>
                    {% for t in collector.transformations %}
                        <tr>
                            <td>
                                {% if t.direction == 'request' %}
                                    <span title="request (ascending)">↑ request</span>
                                {% else %}
                                    <span title="response (descending)">↓ response</span>
                                {% endif %}
                            </td>
                            <td><code>{{ t.version }}</code></td>
                            <td>{{ t.description }}</td>
                            <td class="text-right">{{ t.duration_ms|number_format(3) }} ms</td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3"><strong>Total</strong></td>
                        <td class="text-right"><strong>{{ collector.totalDurationMs|number_format(3) }} ms</strong></td>
                    </tr>
                </tfoot>
            </table>
        {% else %}
            <p>Aucune transformation appliquée (le client est déjà sur la version la plus récente).</p>
        {% endif %}
    {% endif %}

    {# All registered versions #}
    {% if collector.registeredVersions|length > 0 %}
        <h3>Toutes les versions enregistrées</h3>
        {% set appliedNames = collector.appliedVersionNames %}
        <table>
            <thead>
                <tr>
                    <th>Statut</th>
                    <th>Version</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                {% for v in collector.registeredVersions %}
                    <tr>
                        <td>
                            {% if v.name in appliedNames %}
                                <span title="Appliquée" style="color: var(--color-success, #4f8a10);">✓</span>
                            {% else %}
                                <span title="Non appliquée (antérieure ou égale à la version client)" style="color: #aaa;">–</span>
                            {% endif %}
                        </td>
                        <td><code>{{ v.name }}</code></td>
                        <td>{{ v.description }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        {% if collector.wasVersioned %}
            <p><em>Version client = <code>{{ collector.resolvedVersion }}</code> →
                {% if appliedNames|length == collector.registeredVersions|length %}
                    toutes les versions ont été appliquées.
                {% elseif appliedNames|length == 0 %}
                    aucune version appliquée (client déjà à jour).
                {% else %}
                    {{ appliedNames|length }} version(s) sur {{ collector.registeredVersions|length }} appliquée(s).
                {% endif %}
            </em></p>
        {% endif %}
    {% else %}
        <p>Aucune version enregistrée.</p>
    {% endif %}
{% endblock %}
